FROM python:3.12-slim

LABEL maintainer="Agente Autônomo — Gêmeo VPS"
LABEL description="Gêmeo VPS: monitores globais, planejador, executor financeiro, avaliador"

WORKDIR /app

# Dependências do sistema
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    git \
    && rm -rf /var/lib/apt/lists/*

# Dependências Python
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Código do agente
COPY shared/ ./shared/
COPY vps/ ./vps/
COPY config/ ./config/

# Variáveis de ambiente padrão
ENV AGENT_TWIN=vps
ENV AGENT_ENV=production
ENV PYTHONPATH=/app

EXPOSE 8000 8765

CMD ["python", "-m", "vps.main"]
